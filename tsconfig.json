{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./chatbot/*"],
      "@@/*": ["./*"],
      "@dovepaw/agent-sdk": ["./packages/agent-sdk/src/index.ts"]
    },
    "noEmit": true
  },
  "include": [
    "agents/**/*.ts",
    "agent-local/**/*.ts",
    "packages/**/*.ts",
    "lib/**/*.ts",
    "plist/**/*.ts",
    "build.ts",
    "scripts/**/*.ts",
    "docker/**/*.mjs",
    "next.config.ts",
    "vitest.config.ts",
    "tsup.config.ts",
    "chatbot/**/*.ts",
    "chatbot/**/*.tsx",
    "chatbot/next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next/dev/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "chatbot/.next", "agents"]
}
